// Prisma schema — https://pris.ly/d/prisma-schema
// Prisma 7 uses the `prisma-client` generator (TypeScript client emitted to
// ./generated/prisma). Run `npx prisma generate` after changing this file and
// `npx prisma migrate dev --name <name>` to create/apply migrations.

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  // Emit a CommonJS client. The default ESM output uses `import.meta`, which
  // ts-jest's CommonJS VM can't load; CJS works in both jest and the webpack
  // build. See server/CLAUDE.md (Prisma 7 notes) and the webpack extensionAlias.
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String  @id @default(uuid())
  email String  @unique
  name  String?
  // bcrypt/argon2id hash of the password — never returned by the API (the
  // "safe user" object omits it). VarChar(255) comfortably fits bcrypt (60) and
  // argon2id (~96+) outputs. Required: every user authenticates with a password.
  passwordHash String   @db.VarChar(255)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
