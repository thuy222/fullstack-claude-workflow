{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../../..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@app/prisma(|/.*)$": "<rootDir>/libs/prisma/src$1",
    "^@app/common(|/.*)$": "<rootDir>/libs/common/src$1",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "globalSetup": "<rootDir>/apps/api/test/setup-e2e.ts"
}
