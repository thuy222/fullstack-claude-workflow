# Copy to .env.test (gitignored). Connection string for the e2e test database —
# the `db-test` service in docker-compose.yml, exposed on :5434.
# Loaded by `npm run test:e2e` via dotenv-cli. Start the DB first: `npm run db:test:up`.
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/app_test?schema=public"
